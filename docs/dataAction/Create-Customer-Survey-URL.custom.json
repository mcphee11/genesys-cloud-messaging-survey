{
  "name": "Create-Customer-Survey-URL",
  "integrationType": "purecloud-data-actions",
  "actionType": "custom",
  "config": {
    "request": {
      "requestUrlTemplate": "/api/v2/quality/surveys",
      "requestType": "POST",
      "headers": {},
      "requestTemplate": "${input.rawRequest}"
    },
    "response": {
      "translationMap": {},
      "translationMapDefaults": {},
      "successTemplate": "${rawResult}"
    }
  },
  "contract": {
    "input": {
      "inputSchema": {
        "type": "object",
        "properties": {
          "surveyFormContextId": {
            "type": "string"
          },
          "conversationId": {
            "type": "string"
          }
        }
      }
    },
    "output": {
      "successSchema": {
        "type": "object",
        "properties": {
          "customerSurveyUrl": {
            "type": "string"
          }
        }
      }
    }
  },
  "secure": false
}
